# Database
DATABASE_URL=postgresql://user:password@localhost:5432/storywall?schema=public

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/discover
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/discover

STRIPE_SECRET_KEY=sk_test_YOUR_ACTUAL_TEST_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# Public site URL (canonical links + Open Graph). Use your production domain in deploy.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: feedback URL for Discover → How it works (defaults to GitHub new issue)
# NEXT_PUBLIC_FEEDBACK_URL=https://github.com/Kunle123/StoryWall/issues/new

# Optional: Loom/YouTube URL — shows “Watch demo” on discover → How it works ([#16])
# NEXT_PUBLIC_FOUNDER_DEMO_URL=https://www.youtube.com/watch?v=…

# Google Analytics (funnel events in lib/analytics.ts)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Cloudinary (Image Upload)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Conversational editor beta: show link on /editor to /editor/chat (skeleton milestones API)
# NEXT_PUBLIC_CONVERSATIONAL_EDITOR=1

# OpenAI (AI Features)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Stability AI (Alternative for image generation)
# STABILITY_API_KEY=your_stability_api_key
