# Server Configuration
PORT=3002
NODE_ENV=development

# Service URLs
USER_SERVICE_URL=http://user-service:3000
TIMELINE_SERVICE_URL=http://timeline-service:3001

# JWT Configuration (for token verification)
JWT_SECRET=your_jwt_secret_key

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8080,http://localhost:4000

# Service Monitoring
SERVICE_CHECK_INTERVAL=30000 # milliseconds

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100 